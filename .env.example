################################################
# Application
################################################
NODE_ENV=production

################################################
# Server
################################################
PORT=5000

################################################
# Database
################################################
MONGODB_URI=mongodb://localhost:27017/hm_backend

################################################
# JWT
################################################
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_PRODUCTION_SECRET
JWT_EXPIRE=7d

################################################
# QR Payment
################################################
MERCHANT_UPI_ID=merchant@upi
MERCHANT_NAME=Harglim Publishers
MERCHANT_CODE=
PAYMENT_CURRENCY=INR
QR_EXPIRY_MINUTES=15

################################################
# Email
################################################
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

################################################
# Cloudinary
################################################
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

################################################
# AWS S3
################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=

################################################
# Testing
################################################
MONGOMS_DOWNLOAD_DIR=node_modules/.cache/mongodb-binaries
